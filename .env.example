# =========================================
# Configuration de l'Application
# =========================================
# Copier ce fichier en .env.local pour des configurations personnalisées

# =========================================
# BASE DE DONNÉES
# =========================================


# Configuration d'acces à la base de données pour php
DB_HOST=localhost
DB_NAME=iran_actu
DB_USER=dev
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_CHARSET=utf8mb4

# =========================================
# APPLICATION
# =========================================
APP_NAME=Le Monde - Iran Actu
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/TPIran/actu-gerre-iran-3197-3370

# =========================================
# PAGINATION
# =========================================
ITEMS_PER_PAGE=9
TICKERS_PER_PAGE=10

# =========================================
# SÉCURITÉ
# =========================================
SESSION_TIMEOUT=3600
ENABLE_CSRF=true

# =========================================
# CACHE
# =========================================
CACHE_ENABLED=false
CACHE_EXPIRY=3600

# =========================================
# LOGGING
# =========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
